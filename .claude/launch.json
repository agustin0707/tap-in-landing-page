{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "live-server (hot reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=5500", "--open=index.html"],
      "port": 5500
    },
    {
      "name": "serve (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3000"],
      "port": 3000
    },
    {
      "name": "http-server (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "-o"],
      "port": 8080
    }
  ]
}
